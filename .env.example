# Analytics dashboard configuration
# Copy this file to .env and fill in your values

# GitHub personal access token (needs repo scope for traffic data)
GITHUB_TOKEN=

# PostHog personal API key (Settings → Personal API Keys)
POSTHOG_PERSONAL_API_KEY=

# PostHog project ID (visible in the project URL)
POSTHOG_PROJECT_ID=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID (your user ID or group/channel ID)
# Get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=
